@reboot /home/USERNAME/ghcontrol/scripts/log_event.sh "Started USERNAME computer, cron log is CRON_LOG"
@reboot sleep 7s && /home/USERNAME/ghcontrol/on_reset/heater_restart.sh >> CRON_LOG 2>&1
@reboot sleep 9s && /home/USERNAME/ghcontrol/on_reset/temperature_read.sh >> CRON_LOG 2>&1
@reboot sleep 11s && /home/USERNAME/ghcontrol/on_reset/control_temp.sh >> /home/USERNAME/ghcontrol/logs/$(date "+%F").control.log 2>&1
@reboot sleep 13s &&  /home/USERNAME/ghcontrol/on_reset/buttons_setup.sh >> CRON_LOG 2>&1
